{# Rethinking Society — shared macros. Keeps episode markup, the local
   section sub-nav, and the language switch consistent across every
   Rethinking Society page without duplicating markup. #}

{% macro subnav(active) %}
<nav class="rs-subnav" aria-label="Rethinking Society sections">
  <a href="/rethinking-society/" class="{{ 'active' if active == 'main' }}">About the Series</a>
  <a href="/rethinking-society/episodes/" class="{{ 'active' if active == 'episodes' }}">Watch the Episodes</a>
  <a href="/rethinking-society/gathering-library/" class="{{ 'active' if active == 'library' }}">Gathering Library</a>
  <a href="/rethinking-society/gather-online/" class="{{ 'active' if active == 'gather' }}">Gather Online</a>
  <a href="/rethinking-society/support/" class="{{ 'active' if active == 'support' }}">Support the Work</a>
  <a href="/rethinking-society/partners/" class="{{ 'active' if active == 'partners' }}">Partners &amp; Supporters</a>
</nav>
{% endmacro %}

{% macro episodeNum(n) %}{% if n < 10 %}0{{ n }}{% else %}{{ n }}{% endif %}{% endmacro %}

{% macro statusLabel(status) %}{% if status == 'published' %}Published{% else %}Draft{% endif %}{% endmacro %}

{# Compact card — used on the /episodes/ archive and the old featured-3 grid #}
{% macro episodeCard(ep) %}
<article class="card">
  <div class="card__media">
    {% if ep.data.thumbnail %}
      <img src="{{ ep.data.thumbnail }}" alt="{{ ep.data.title }}" loading="lazy" />
    {% else %}
      <div class="placeholder" style="height:100%; min-height:0;">[ episode {{ episodeNum(ep.data.number) }} thumbnail ]</div>
    {% endif %}
  </div>
  <div class="card__body">
    <span class="frame__num">{{ episodeNum(ep.data.number) }}</span>
    <h3 class="t-h3">{{ ep.data.title }}</h3>
    <p class="t-body t-pretty">{{ ep.data.question }}</p>
    {% if ep.data.topics and ep.data.topics.length %}
    <div class="rs-tags">{% for t in ep.data.topics %}<span>{{ t }}</span>{% endfor %}</div>
    {% endif %}
    <div style="display:flex; gap: var(--sp-4); flex-wrap:wrap; align-items:center; margin-top:auto; padding-top: var(--sp-2);">
      {% if ep.data.videoUrl %}
        <a class="btn btn--ghost" href="{{ ep.data.videoUrl }}" target="_blank" rel="noopener noreferrer">Watch</a>
      {% else %}
        <span class="t-meta">Video coming soon</span>
      {% endif %}
      <a class="link-chev" href="/rethinking-society/episodes/{{ ep.data.slug }}/">Episode page</a>
      {% if ep.data.resources and ep.data.resources.length %}
        <a class="link-chev" href="/rethinking-society/gathering-library/#{{ ep.data.slug }}">Resources</a>
      {% endif %}
    </div>
  </div>
</article>
{% endmacro %}

{# English/Swedish PDF resource button label, by canonical resource type #}
{% macro resourceLabel(type, lang) %}
  {%- set labels = {
    "One-Page Conversation Starter": { en: "Get the Conversation Starter", sv: "Samtalsstartare" },
    "Discussion Guide":              { en: "Get the Discussion Guide",     sv: "Samtalsguide" },
    "Worksheet Pack":                { en: "Get the Worksheet Pack",       sv: "Arbetsbladspaket" },
    "Facilitator Edition":           { en: "Get the Facilitator Edition",  sv: "Handledarutgåva" },
    "Circle Kit":                    { en: "Get the Circle Kit",           sv: "Material för samtalscirklar" },
    "Print-Shop Edition":            { en: "Get the Print-Shop Edition",   sv: "Tryckeri- och Etsy-utgåva" },
    "Complete Episode Bundle":       { en: "Get the Complete Bundle",      sv: "Komplett paket" }
  } -%}
  {%- if labels[type] -%}{{ labels[type][lang] }}{%- else -%}{{ type }}{%- endif -%}
{% endmacro %}

{# Compact "jump to an episode" row, near the top of each language page #}
{% macro episodeNav(episodes, anchorPrefix, lang) %}
<nav class="rs-ep-nav" aria-label="{{ 'Jump to an episode' if lang == 'en' else 'Hoppa till ett avsnitt' }}">
  {% for ep in episodes %}
  <a href="#{{ anchorPrefix }}-{{ ep.data.number }}">{{ episodeNum(ep.data.number) }}</a>
  {% endfor %}
</nav>
{% endmacro %}

{# English | Svenska switcher #}
{% macro langSwitch(current) %}
<p class="rs-lang-switch">
  <a href="/rethinking-society/" class="{{ 'active' if current == 'en' }}" lang="en">English</a>
  <span aria-hidden="true">|</span>
  <a href="/sv/rethinking-society/" class="{{ 'active' if current == 'sv' }}" lang="sv">Svenska</a>
</p>
{% endmacro %}

{# Full inline episode section — the core unit of the bilingual main page.
   translationUrl/translationLabel are pre-computed by the calling page
   (look up the OTHER language's collection by translationKey) so this
   macro stays a stateless renderer. #}
{% macro episodeSection(ep, lang, anchorPrefix, translationUrl, translationLabel) %}
<article class="rs-ep-section" id="{{ anchorPrefix }}-{{ ep.data.number }}">
  <div class="rs-ep-section__media">
    {% if ep.data.videoUrl %}
      <div class="rs-video rs-yt-facade" data-yt-facade data-embed-src="https://www.youtube-nocookie.com/embed/{{ ep.data.videoUrl | youtubeId }}" role="button" tabindex="0" aria-label="{{ 'Play video' if lang == 'en' else 'Spela video' }}: {{ ep.data.title }}">
        {% if ep.data.thumbnail %}
          <img src="{{ ep.data.thumbnail }}" alt="" loading="lazy" />
        {% else %}
          <img src="https://img.youtube.com/vi/{{ ep.data.videoUrl | youtubeId }}/hqdefault.jpg" alt="" loading="lazy" />
        {% endif %}
        <span class="rs-yt-facade__play" aria-hidden="true"></span>
      </div>
    {% else %}
      <div class="rs-video">
        <div class="placeholder" style="height:100%; min-height:0;">{{ 'Video coming soon' if lang == 'en' else 'Video kommer snart' }}</div>
      </div>
    {% endif %}
  </div>
  <div class="rs-ep-section__body">
    <span class="frame__num">{{ episodeNum(ep.data.number) }}</span>
    <h2 class="t-h3">{{ ep.data.title }}</h2>

    {% if ep.data.runtime or ep.data.date %}
    <p class="t-meta" style="margin-top: -0.25rem;">
      {%- if ep.data.runtime %}{{ ep.data.runtime }}{% endif -%}
      {%- if ep.data.runtime and ep.data.date %} · {% endif -%}
      {%- if ep.data.date %}{{ ep.data.date | date("DD MMMM YYYY") }}{% endif -%}
    </p>
    {% endif %}

    <p class="t-lead t-pretty rs-ep-section__spaced">{{ ep.data.question }}</p>

    {% if ep.data.key_questions and ep.data.key_questions.length %}
    <ul class="rs-ep-section__list rs-ep-section__spaced">
      {% for q in ep.data.key_questions %}<li class="t-body t-pretty">{{ q }}</li>{% endfor %}
    </ul>
    {% endif %}

    {% if ep.data.short_description %}<p class="t-body t-pretty rs-ep-section__spaced">{{ ep.data.short_description }}</p>{% endif %}

    {% if ep.data.topics and ep.data.topics.length %}
    <div class="rs-tags rs-ep-section__spaced">{% for t in ep.data.topics %}<span>{{ t }}</span>{% endfor %}</div>
    {% endif %}

    {% if ep.data.themes and ep.data.themes.length %}
    <div class="rs-ep-section__spaced">
      <p class="t-eyebrow">{{ 'Main themes' if lang == 'en' else 'Huvudteman' }}</p>
      <ul class="rs-ep-section__list" style="margin-top: var(--sp-2);">
        {% for theme in ep.data.themes %}<li class="t-body">{{ theme.theme }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if ep.data.quotes and ep.data.quotes.length %}
    <div class="rs-ep-section__quotes rs-ep-section__spaced">
      {% for q in ep.data.quotes %}
      <p class="rs-ep-section__quote-line">{% if q.mark %}<span class="rs-ep-section__quote-mark">{{ q.mark }}</span>{% endif %}<em>{{ q.text }}</em></p>
      {% endfor %}
    </div>
    {% endif %}

    {% if ep.data.resources and ep.data.resources.length %}
    <div class="rs-ep-section__resources rs-ep-section__spaced">
      {% for r in ep.data.resources %}
        {% if r.url %}
          <a class="btn btn--ghost" href="{{ r.url }}" target="_blank" rel="noopener noreferrer">{{ resourceLabel(r.type, lang) }}</a>
        {% else %}
          <span class="t-meta">{{ resourceLabel(r.type, lang) }} — {{ 'available soon' if lang == 'en' else 'kommer snart' }}</span>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    <p class="t-body t-pretty rs-ep-section__spaced" style="font-style:italic;">
      {% if ep.data.cta %}{{ ep.data.cta }}
      {% elif lang == 'en' %}Watch, then bring the question into a conversation.
      {% else %}Titta, och ta sedan med frågan in i ett samtal.
      {% endif %}
    </p>

    <div class="rs-ep-section__actions rs-ep-section__spaced">
      <button class="btn btn--ghost" type="button" data-copy-link data-copy-href="#{{ anchorPrefix }}-{{ ep.data.number }}" data-copied-label="{{ 'Link copied' if lang == 'en' else 'Länk kopierad' }}">{{ 'Copy link' if lang == 'en' else 'Kopiera länk' }}</button>
      {% if translationUrl %}<a class="link-chev" href="{{ translationUrl }}">{{ translationLabel }}</a>{% endif %}
    </div>
  </div>
</article>
{% endmacro %}
