<!DOCTYPE html>
<html lang="{{ pageLang or 'en' }}">
<head>
<meta charset="UTF-8" />
<style>
html                    { background: oklch(95.8% 0.008 155); }
html[data-theme="dark"] { background: oklch(18%   0.014 160); }
</style>
<script>
(function(){
  var t = localStorage.getItem('vw-theme');
  if (t) document.documentElement.setAttribute('data-theme', t);
  else if (window.matchMedia('(prefers-color-scheme: dark)').matches)
    document.documentElement.setAttribute('data-theme', 'dark');
})();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title }}</title>
<meta name="description" content="{{ description }}" />
{% set canonicalUrl = canonical or ("https://verdandiweaver.com" + page.url) %}
<link rel="canonical" href="{{ canonicalUrl }}" />
{% if hreflangAlternates %}{% for lang, url in hreflangAlternates %}<link rel="alternate" hreflang="{{ lang }}" href="{{ url }}" />
{% endfor %}{% endif %}

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Verdandi Weaver" />
<meta property="og:title" content="{{ ogTitle or title }}" />
<meta property="og:description" content="{{ ogDescription or description }}" />
<meta property="og:url" content="{{ canonicalUrl }}" />
{% if ogImage %}<meta property="og:image" content="https://verdandiweaver.com{{ ogImage }}" />{% endif %}
<meta name="twitter:card" content="{{ 'summary_large_image' if ogImage else 'summary' }}" />
<meta name="twitter:title" content="{{ ogTitle or title }}" />
<meta name="twitter:description" content="{{ ogDescription or description }}" />
{% if ogImage %}<meta name="twitter:image" content="https://verdandiweaver.com{{ ogImage }}" />{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Person", "name": "Sara Leidelmeijer", "alternateName": "Verdandi Weaver", "url": "https://verdandiweaver.com" },
    { "@type": "WebSite", "name": "Verdandi Weaver", "url": "https://verdandiweaver.com" }
  ]
}
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Sorts+Mill+Goudy:ital@0;1&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&display=block" rel="stylesheet" />
<link rel="stylesheet" href="/assets/tokens.css?v={{ buildVersion }}" />
<link rel="stylesheet" href="/assets/components.css?v={{ buildVersion }}" />
<link rel="stylesheet" href="/assets/consent.css?v={{ buildVersion }}" />
</head>
<body data-nav-section="{{ navSection or '' }}">

{% set currentUrl = page.url %}
{% include "nav.njk" %}

{{ content | safe }}

{% include "footer.njk" %}

{% include "consent.njk" %}

<script src="/assets/consent.js?v={{ buildVersion }}"></script>
<script src="/assets/app.js?v={{ buildVersion }}"></script>
{% block extraScripts %}{% endblock %}
</body>
</html>
