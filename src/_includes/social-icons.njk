{# Minimal single-color line icons (matches the nav's theme-toggle icon
   style: viewBox 24x24, stroke=currentColor, no brand colors). Purely
   decorative — the visible platform name next to each one is what
   actually carries the accessible name, so these are aria-hidden. #}
{% macro icon(name) %}
  {%- if name == "substack" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><rect x="4" y="3" width="16" height="18" rx="2"/><line x1="7.5" y1="8" x2="16.5" y2="8"/><line x1="7.5" y1="12" x2="16.5" y2="12"/><line x1="7.5" y1="16" x2="13" y2="16"/></svg>
  {%- elif name == "youtube" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><rect x="3" y="6" width="18" height="12" rx="3"/><path d="M10.3 9.3l5 2.7-5 2.7z" fill="currentColor" stroke="none"/></svg>
  {%- elif name == "instagram" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17" cy="7" r="0.9" fill="currentColor" stroke="none"/></svg>
  {%- elif name == "facebook" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9"/><path d="M13.4 9.3h-1.1c-.7 0-1.3.6-1.3 1.3v1.6h2.3l-.3 2h-2V19"/></svg>
  {%- elif name == "tiktok" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><circle cx="9.5" cy="16.5" r="2.5"/><path d="M12 16.5V4.5c1 1.8 2.7 3 4.7 3.2"/></svg>
  {%- elif name == "pinterest" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9"/><path d="M9.6 18c.5-2.3 1.1-4.9 1.6-7.2.2-1 1-1.7 2-1.7 1.4 0 2.3 1 2.3 2.4 0 2-1.1 3.9-3 3.9-.5 0-1-.2-1.2-.6"/></svg>
  {%- elif name == "patreon" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><circle cx="13.5" cy="9.5" r="5.5"/><line x1="6.5" y1="4" x2="6.5" y2="20"/></svg>
  {%- elif name == "coffee" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><path d="M5 9h11v5a4 4 0 0 1-4 4H9a4 4 0 0 1-4-4V9z"/><path d="M16 10.5h1.2a2.3 2.3 0 0 1 0 4.5H16"/><path d="M8.2 6c0-.9.8-1.2.8-2.2M11.4 6c0-.9.8-1.2.8-2.2"/></svg>
  {%- elif name == "heart" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><path d="M12 19s-7-4.4-7-9.4A4 4 0 0 1 12 7a4 4 0 0 1 7 2.6C19 14.6 12 19 12 19z"/></svg>
  {%- endif -%}
{% endmacro %}
