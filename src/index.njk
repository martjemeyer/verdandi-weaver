<section class="section section--sunk fade-up">
  <div class="container">
    <header class="section-header">
      <p class="t-eyebrow">The core idea</p>
      <h2 class="t-h2 t-balance">A human being is a living system, growing inside living systems</h2>
      <p class="t-lead t-pretty">Soul, mind, nervous system, body, identity, relationships — rooted in soil, water, ancestry; reaching into air and light.</p>
      <span class="rule"></span>
    </header>
    <div class="grid grid-2" style="align-items:center; gap: var(--sp-8);">
      <div class="clearing">
        <div class="placeholder" style="height: 400px; border-radius: var(--radius-lg);">[ image ]</div>
      </div>
      <div class="stack-lg">
        <p class="t-lead t-pretty">You are not a soul living above a body. You are a soul, in a body, in a nervous system, in a culture, in a forest of other living systems.</p>
        <p class="t-body t-pretty">Wholeness begins when nothing in you is left out — when the parts stop competing for who gets to be real, and the roots, trunk, and canopy remember they are one tree.</p>
        <p class="t-body t-pretty"><em>You are not separate from what you grow inside.</em></p>
        <a class="link-chev" href="/frameworks.html">Read the full framework</a>
      </div>
    </div>
  </div>
</section>

<section class="section fade-up">
  <div class="container">
    <header class="section-header">
      <p class="t-eyebrow">A library</p>
      <h2 class="t-h2">Books</h2>
      <p class="t-lead t-pretty">Slow reading for grounded awakening — being human, belonging, and the long return to oneself.</p>
    </header>
    <div class="grid grid-3">
      {% set books = collections.book | sort(false, false, "data.order") %}
      {% for book in books | first(3) %}
      <a class="book" href="{{ book.data.href if book.data.href else '/books.html' }}">
        {% if book.data.image %}
        <div class="book__cover book__cover--img"><img src="{{ book.data.image }}" alt="{{ book.data.title }}" /></div>
        {% else %}
        <div class="book__cover book__cover--{{ book.data.cover }}">{{ book.data.title }}</div>
        {% endif %}
        <span class="book__title">{{ book.data.title }}</span>
        <span class="book__meta">{{ book.data.meta }}</span>
      </a>
      {% endfor %}
    </div>
    <div class="center-text" style="margin-top: var(--sp-7);">
      <a class="btn btn--ghost" href="/books.html">See all {{ collections.book | length }} titles →</a>
    </div>
  </div>
</section>

<section class="section compact section--sunk fade-up">
  <div class="container narrow center-text">
    <p class="pull t-balance">You do not awaken out of being human.<br/><em>You awaken into it.</em></p>
