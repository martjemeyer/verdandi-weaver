---
layout: layouts/base.njk
title: The Living Archive — Verdandi Weaver
description: A living, interconnected ecology of reflections, videos, deep reads, frameworks, guides and gatherings — wander by theme, not by category.
permalink: /ecosystem.html
---

<section class="hero container fade-up">
  <p class="t-eyebrow hero__eyebrow">A living archive</p>
  <h1 class="t-h1 hero__title t-balance">Wander, don't search</h1>
  <p class="t-lead hero__lead t-pretty">Reflections, videos, deep reads, frameworks, guides and gatherings — one body, interconnected. Choose a thread, and the archive rearranges around it.</p>
</section>

<section class="section fade-up">
  <div class="container">

    <div class="lens" data-lens role="tablist" aria-label="Themes">
      <button class="lens__chip lens__chip--all" data-theme="all" aria-pressed="true">all of it</button>
      <button class="lens__chip" data-theme="nervous-systems"   aria-pressed="false">nervous systems</button>
      <button class="lens__chip" data-theme="fragmentation"     aria-pressed="false">fragmentation</button>
      <button class="lens__chip" data-theme="awakening"         aria-pressed="false">awakening</button>
      <button class="lens__chip" data-theme="society"           aria-pressed="false">society</button>
      <button class="lens__chip" data-theme="relationships"     aria-pressed="false">relationships</button>
      <button class="lens__chip" data-theme="emotional-ecology" aria-pressed="false">emotional ecology</button>
      <button class="lens__chip" data-theme="grounded-wholeness" aria-pressed="false">grounded wholeness</button>
      <button class="lens__chip" data-theme="collective-life"   aria-pressed="false">collective life</button>
      <button class="lens__chip" data-theme="humanity"          aria-pressed="false">humanity</button>
      <button class="lens__chip" data-theme="eco-wholeness"     aria-pressed="false">Eco-Wholeness</button>
    </div>

    <div class="tabs" data-tabs role="tablist" aria-label="Content kinds">
      <button data-kind="all"     aria-pressed="true">everything</button>
      <button data-kind="reflect" aria-pressed="false">reflections</button>
      <button data-kind="read"    aria-pressed="false">deep reads</button>
      <button data-kind="video"   aria-pressed="false">videos</button>
      <button data-kind="frame"   aria-pressed="false">frameworks</button>
      <button data-kind="guide"   aria-pressed="false">guides &amp; PDFs</button>
      <button data-kind="event"   aria-pressed="false">gatherings</button>
    </div>

    <p class="lens-meta" data-count>showing all {{ collections.ecosystem | length }} entries</p>

    <div class="stream" data-stream>
      {% set entries = collections.ecosystem | sort(false, false, "data.order") %}
      {% for entry in entries %}
      {% set cardHref = entry.data.href %}
      {% if not cardHref and entry.data.kind == 'video' %}{% set cardHref = entry.data.youtube_url %}{% endif %}
      <a class="ent ent--{{ entry.data.kind }}{% if entry.data.wide %} ent--wide{% endif %}{% if entry.data.tall %} ent--tall{% endif %}"
         href="{{ cardHref }}"
         data-kind="{{ entry.data.kind }}"
         data-tags="{{ entry.data.themes | join(',') }}">

        <div class="ent__media{% if entry.data.orientation == 'portrait' %} ent__media--portrait{% endif %}">
          {% if entry.data.image %}
            <img src="{{ entry.data.image }}" alt="{{ entry.data.title }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
          {% elif entry.data.kind == 'video' and entry.data.youtube_url %}
            <iframe
              src="https://www.youtube-nocookie.com/embed/{{ entry.data.youtube_url | youtubeId }}?rel=0"
              title="{{ entry.data.title }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              style="position:absolute;inset:0;width:100%;height:100%;border:0;"></iframe>
          {% elif entry.data.kind == 'video' %}
            <div class="cine"><div class="cine__play" aria-hidden="true"></div></div>
          {% elif entry.data.kind == 'reflect' or entry.data.kind == 'read' %}
            <div class="paper">{{ entry.data.paper_text }}</div>
          {% elif entry.data.kind == 'frame' %}
            <div class="geo">
              {% if entry.data.framework_num == "1" %}
                <svg viewBox="0 0 200 130" aria-hidden="true"><circle cx="70" cy="65" r="34" fill="none" stroke="var(--c-accent)" stroke-width="1.4"/><circle cx="100" cy="65" r="34" fill="none" stroke="var(--c-blue)" stroke-width="1.4"/><circle cx="130" cy="65" r="34" fill="none" stroke="var(--c-warm)" stroke-width="1.4"/></svg>
              {% elif entry.data.framework_num == "4" %}
                <svg viewBox="0 0 200 130" aria-hidden="true"><g fill="none" stroke="var(--c-accent)" stroke-width="1.4" stroke-linecap="round"><line x1="40" y1="30" x2="40" y2="100"/><line x1="160" y1="30" x2="160" y2="100"/><path d="M 40 65 Q 100 25 160 65" stroke-dasharray="2 4"/></g></svg>
              {% elif entry.data.framework_num == "7" %}
                <svg viewBox="0 0 200 130" aria-hidden="true"><g stroke="var(--c-line)" stroke-width="0.8" fill="none"><line x1="55" y1="50" x2="100" y2="38"/><line x1="100" y1="38" x2="150" y2="55"/><line x1="55" y1="50" x2="65" y2="92"/><line x1="65" y1="92" x2="125" y2="98"/><line x1="125" y1="98" x2="150" y2="55"/><line x1="100" y1="38" x2="125" y2="98"/></g><g fill="var(--c-accent-soft)" stroke="var(--c-accent)" stroke-width="1.2"><circle cx="55" cy="50" r="8"/><circle cx="100" cy="38" r="8"/><circle cx="150" cy="55" r="8"/><circle cx="65" cy="92" r="8"/><circle cx="125" cy="98" r="8"/></g></svg>
              {% else %}
                <svg viewBox="0 0 200 130" aria-hidden="true"><circle cx="70" cy="65" r="30" fill="none" stroke="var(--c-accent)" stroke-width="1.4"/><circle cx="130" cy="65" r="30" fill="none" stroke="var(--c-blue)" stroke-width="1.4"/></svg>
              {% endif %}
            </div>
          {% elif entry.data.kind == 'guide' %}
            <div class="folio" data-label="{{ entry.data.folio_pages }}"></div>
          {% elif entry.data.kind == 'event' %}
            <div class="date-tile"><div><div class="date-tile__d">{{ entry.data.event_day }}</div><div class="date-tile__m">{{ entry.data.event_month }}</div></div></div>
          {% endif %}
        </div>

        <span class="ent__type">{{ entry.data.type_label }}</span>
        <h3 class="ent__title">{{ entry.data.title }}</h3>
        {% if entry.data.body %}
        <p class="ent__body">{{ entry.data.body }}</p>
        {% endif %}
        <div class="ent__foot">
          <div class="ent__tags">
            {% for theme in entry.data.themes %}
            <span>{{ theme | replace("-", " ") }}</span>
            {% endfor %}
          </div>
          <span>{{ entry.data.cta }}</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--sunk fade-up">
  <div class="container">
    <div class="section-header" style="text-align: left; align-items: flex-start; margin-bottom: var(--sp-5);">
      <p class="t-eyebrow">Where the archive becomes relational</p>
      <h2 class="t-h2 t-balance">Three scales of one conversation</h2>
      <p class="t-lead" style="text-align: left; max-width: 56ch;">Beyond the archive, three living rooms — for meeting the work in company. Different sizes of the same slow inquiry.</p>
    </div>
    <div class="scales">
      <a class="scale" href="/one-to-one.html"><span class="scale__num">scale i</span><h3 class="scale__title">One-to-one</h3><p class="scale__sub">A quiet room, an unhurried hour.</p><span class="scale__more">Enter the room</span></a>
      <a class="scale" href="/circles.html"><span class="scale__num">scale ii</span><h3 class="scale__title">Circles</h3><p class="scale__sub">Modern relational campfires. 8–10 humans.</p><span class="scale__more">Sit at the fire</span></a>
      <a class="scale" href="/events.html"><span class="scale__num">scale iii</span><h3 class="scale__title">Live explorations</h3><p class="scale__sub">Wider rooms of shared looking.</p><span class="scale__more">See what's exploring</span></a>
    </div>
    <p class="t-meta center-text" style="margin-top: var(--sp-6); font-family: var(--font-display); font-style: italic; font-size: var(--fs-md);">
      You are allowed to arrive as you are. <a href="/spaces.html" style="color: var(--c-accent); text-decoration: none; border-bottom: 1px solid currentColor;">All three, together</a>.
    </p>
  </div>
</section>

<section class="stay fade-up" aria-labelledby="stay-title">
  <div class="container">
    <div class="stay__inner">
      <span class="stay__mark" aria-hidden="true"></span>
      <h2 class="stay__title" id="stay-title">Stay near</h2>
      <p class="stay__sub">Slow reflections, new frameworks, future gatherings, and quiet things worth sharing.</p>
      <form class="stay__form" onsubmit="event.preventDefault(); this.querySelector('button').textContent='kept near';">
        <input type="email" placeholder="your email, if you'd like to stay near" aria-label="Email" required />
        <button type="submit">Stay near</button>
      </form>
      <p class="stay__note">A letter every few weeks. Never a funnel. Unsubscribe with one tap.</p>
    </div>
  </div>
</section>

<section class="section fade-up">
  <div class="container narrow center-text">
    <p class="pull t-balance">A library is <em>not</em> a list. It is a forest.<br/>Wander until something looks back.</p>
  </div>
</section>

{% block extraScripts %}
<script>
(function () {
  const lens   = document.querySelector('[data-lens]');
  const tabs   = document.querySelector('[data-tabs]');
  const stream = document.querySelector('[data-stream]');
  const count  = document.querySelector('[data-count]');
  if (!lens || !tabs || !stream) return;

  let activeTheme = 'all';
  let activeKind  = 'all';
  const cards = Array.from(stream.children);

  function pretty(t) {
    return t.replace(/-/g, ' ').replace(/eco wholeness/, 'Eco-Wholeness');
  }

  function applyFilter() {
    let shown = 0;
    cards.forEach(c => {
      const tags    = (c.dataset.tags || '').split(',');
      const okKind  = activeKind  === 'all' || activeKind  === c.dataset.kind;
      const okTheme = activeTheme === 'all' || tags.includes(activeTheme);
      c.hidden = !(okKind && okTheme);
      if (!c.hidden) shown++;
    });
    let msg = `showing ${shown} ${shown === 1 ? 'entry' : 'entries'}`;
    const parts = [];
    if (activeKind  !== 'all') parts.push(activeKind === 'reflect' ? 'reflections' : activeKind === 'read' ? 'deep reads' : activeKind === 'video' ? 'videos' : activeKind === 'frame' ? 'frameworks' : activeKind === 'guide' ? 'guides' : 'gatherings');
    if (activeTheme !== 'all') parts.push('through "' + pretty(activeTheme) + '"');
    if (parts.length) msg += ' · ' + parts.join(' ');
    count.textContent = msg;
  }

  lens.addEventListener('click', e => {
    const b = e.target.closest('[data-theme]');
    if (!b) return;
    activeTheme = b.dataset.theme;
    lens.querySelectorAll('[data-theme]').forEach(x => x.setAttribute('aria-pressed', String(x === b)));
    applyFilter();
  });
  tabs.addEventListener('click', e => {
    const b = e.target.closest('[data-kind]');
    if (!b) return;
    activeKind = b.dataset.kind;
    tabs.querySelectorAll('[data-kind]').forEach(x => x.setAttribute('aria-pressed', String(x === b)));
    applyFilter();
  });

  applyFilter();
})();
</script>
{% endblock %}
